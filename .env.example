# ============================================================
# MKGE — Environment Variables
# Copy file nay thanh .env va dien gia tri thuc
# ============================================================

# --- Auth ---
JWT_SECRET=change_me_to_random_64_char_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL (Supabase) ---
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# --- Neo4j (Aura Free) ---
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=xxxx

# --- Qdrant Cloud ---
QDRANT_URL=https://xxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=xxxx

# --- Redis (Upstash hoac local) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AI APIs ---
GEMINI_API_KEY=xxxx
GROQ_API_KEY=xxxx

# --- Embedding (KHONG doi sau khi co data) ---
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMS=768

# --- App ---
APP_ENV=development
MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_UPLOAD_PER_HOUR=5
RATE_LIMIT_QUERY_PER_HOUR=30
UPLOAD_DIR=uploads
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
